# Backend environment variables (copy to .env and fill in)
# Upstox API access token (regenerate the one you shared; keep this secret)
UPSTOX_TOKEN=your_upstox_access_token_here

# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI)
# Use the "Session" pooler URI. Note the +pg8000 driver suffix (pure-Python driver).
DATABASE_URL=postgresql+pg8000://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Comma-separated allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173

# Quote cache TTL in seconds
QUOTE_CACHE_TTL=60
