# Backend environment variables (copy to .env and fill in)
# Upstox API access token (regenerate the one you shared; keep this secret)
UPSTOX_TOKEN=your_upstox_access_token_here

# Supabase Postgres connection string (Project Settings -> Database -> Connection string).
# Use the "Session pooler" URI (IPv4-friendly). The user is `postgres.<PROJECT_REF>`
# and the host is `aws-<N>-<REGION>.pooler.supabase.com`. Note the +pg8000 suffix.
DATABASE_URL=postgresql+pg8000://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# Comma-separated allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173

# Quote cache TTL in seconds
QUOTE_CACHE_TTL=60
